# --- Banco de dados (obrigatório) ---
# String de conexão do Postgres. No CapRover, use o hostname interno srv-captain--NOME.
DATABASE_URL="postgresql://bdayfm:SENHA_FORTE_AQUI@srv-captain--bday-db:5432/bday"

# --- Conta administrativa (opcional, mas recomendado) ---
# Se definidas, o boot cria/atualiza a conta ADMIN (idempotente). Senha >= 10 caracteres.
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="troque-por-uma-senha-forte"

# --- Mercado Pago (opcional — habilita depósitos na carteira) ---
# Access Token de PRODUÇÃO da sua aplicação (Suas integrações -> Credenciais de produção).
MP_ACCESS_TOKEN=""
# Chave secreta do webhook (Webhooks -> sua notificação) — usada para validar a assinatura.
MP_WEBHOOK_SECRET=""
