// bday.fm — schema do banco (PostgreSQL)
// Fase 1: usuários + sessões (autenticação real).
// Já modelados para as próximas fases: presentes, carteira (ledger), metas de grupo.

generator client {
  provider        = "prisma-client-js"
  engineType      = "client"
  previewFeatures = ["queryCompiler", "driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  slug         String    @unique // bday.fm/<slug>
  name         String
  email        String    @unique
  passwordHash String
  birthdate    DateTime? @db.Date
  bio          String?
  avatarUrl    String?
  coverUrl     String?
  role         Role      @default(USER)
  verified     Boolean   @default(false)
  // campos visuais que o front já usa (frame, accessory, badges)
  frame        String?
  accessory    String?
  badge        String? // emblema equipado
  badges       String[]  @default([])
  socials      Json?     // { instagram, tiktok, youtube, linkedin }
  // saque Pix
  pixKey       String?
  pixKeyType   String?   // cpf | cnpj | email | phone | random
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions          Session[]
  giftsReceived     GiftSent[]         @relation("receiver")
  giftsGiven        GiftSent[]         @relation("sender")
  walletEntries     WalletEntry[]
  goals             Goal[]
  goalContributions GoalContribution[]
  friendRequestsSent     Friendship[]  @relation("requester")
  friendRequestsReceived Friendship[]  @relation("addressee")
  feedPosts         FeedPost[]
  feedLikes         FeedLike[]
  feedComments      FeedComment[]
  withdrawals       Withdrawal[]
  items             UserItem[]
  pointEntries      PointEntry[]
  supportTickets    SupportTicket[]
  notifications       Notification[] @relation("notifOwner")
  notificationsCaused Notification[] @relation("notifActor")

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique // sha256 do token; o token em si só vive no cookie
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
  @@index([expiresAt])
}

// ---------- Fase 2 (já modelado, sem uso ainda) ----------

// Catálogo de presentes digitais (Biscoito da Sorte, Balão de Festa, etc.)
model GiftItem {
  id            String     @id @default(cuid())
  name          String     @unique
  emoji         String?
  priceCents    Int        // preço em centavos (nunca float para dinheiro)
  description   String?
  category      String?    // popular | economico | valioso | especial | torpedo
  rarity        String?    // comum | raro | epico | lendario
  physical      Boolean    @default(false)
  partner       String?    // parceiro (presentes físicos)
  baseSentCount Int        @default(0) // prova social inicial exibida no site
  sortOrder     Int        @default(0)
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  sent          GiftSent[]
}

model GiftSent {
  id         String   @id @default(cuid())
  giftItemId String
  giftItem   GiftItem @relation(fields: [giftItemId], references: [id])
  senderId   String
  sender     User     @relation("sender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("receiver", fields: [receiverId], references: [id])
  message    String?
  valueCents Int
  createdAt  DateTime @default(now())

  @@index([receiverId, createdAt])
}

enum WalletEntryType {
  DEPOSIT_MP
  GIFT_RECEIVED
  GIFT_SENT
  STORE_PURCHASE
  WITHDRAWAL_PIX
  ADJUSTMENT
}

// Ledger imutável: saldo = soma dos lançamentos. Nunca se edita, só se acrescenta.
model WalletEntry {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        WalletEntryType
  amountCents Int             // positivo = crédito, negativo = débito
  reference   String?         // id do GiftSent, id da transação Pix no gateway, etc.
  createdAt   DateTime        @default(now())

  @@index([userId, createdAt])
}

model Goal {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  title        String
  targetCents  Int
  description  String?
  category     String?
  date         String?            // data do evento exibida no card (texto livre)
  imageUrl     String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  contributions GoalContribution[]
}

model GoalContribution {
  id          String   @id @default(cuid())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  amountCents Int
  createdAt   DateTime @default(now())

  @@index([goalId])
}

// ---------- Fase 3: social, comércio, saques, suporte ----------

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User             @relation("addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}

model FeedPost {
  id         String        @id @default(cuid())
  authorId   String
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  caption    String
  image      String?       // dataURL ou URL
  attachType String?       // 'bday' | 'recap'
  attachData Json?
  createdAt  DateTime      @default(now())
  likes      FeedLike[]
  comments   FeedComment[]

  @@index([createdAt])
}

model FeedLike {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  DONE
  FAILED
  REJECTED
}

model Withdrawal {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  amountCents Int              // valor bruto debitado do saldo
  feeCents    Int              @default(0)
  netCents    Int              // valor líquido a transferir
  speed       String           @default("standard") // standard | instant
  pixKey      String
  pixKeyType  String
  status      WithdrawalStatus @default(REQUESTED)
  adminNote   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

// Catálogo da loja de cosméticos (molduras, decorações)
model StoreItem {
  id          String  @id // ex.: "frame:aurora"
  kind        String  // frame | accessory
  itemId      String  // id usado pelo front (aurora, confete, ...)
  name        String
  priceCents  Int
  pointsPrice Int?
  rarity      String?
  active      Boolean @default(true)
  sortOrder   Int     @default(0)

  @@unique([kind, itemId])
}

// Cosméticos possuídos pelo usuário
model UserItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // frame | accessory
  itemId    String
  source    String   @default("purchase") // purchase | points | reward
  createdAt DateTime @default(now())

  @@unique([userId, kind, itemId])
}

// Ledger de pontos de recompensa (gamificação)
model PointEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int      // positivo = ganho, negativo = gasto
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

enum TicketStatus {
  OPEN
  PENDING
  CLOSED
}

model SupportTicket {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  name      String?
  email     String?
  subject   String
  status    TicketStatus     @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]

  @@index([status, updatedAt])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAdmin Boolean       @default(false)
  text      String
  createdAt DateTime      @default(now())
}

// Parâmetros da plataforma editáveis no admin
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Notificações / atividades do usuário (sininho + página /atividades)
model Notification {
  id        String   @id @default(cuid())
  userId    String   // dono do sininho
  user      User     @relation("notifOwner", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?  // quem causou a atividade
  actor     User?    @relation("notifActor", fields: [actorId], references: [id], onDelete: SetNull)
  type      String   // FRIEND_REQUEST_SENT | FRIEND_REQUEST | FRIEND_ACCEPT | FRIEND_ACCEPTED_BY_YOU | GIFT | TORPEDO | GOAL_CONTRIBUTION | POST_LIKE | POST_COMMENT
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, read])
}
